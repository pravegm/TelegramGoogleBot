# Required
BOT_TOKEN=your_telegram_bot_token
GEMINI_API_KEY=your_gemini_api_key
ALLOWED_USER_ID=your_telegram_user_id

# Your name (used in system prompts and greetings)
USER_NAME=Your Name

# IANA timezone (e.g. America/New_York, Asia/Tokyo, Europe/London)
TIMEZONE=UTC

# Comma-separated list of Google account names
# Each must have a matching token file at ~/.google-mcp/tokens/<name>.json
GOOGLE_ACCOUNTS=account1

# Optional: custom path to Google OAuth credentials directory
# Defaults to ~/.google-mcp
# GOOGLE_CREDS_DIR=/path/to/.google-mcp

# Scheduled message times (cron syntax, runs in your TIMEZONE)
# SCHEDULE_MORNING=0 8 * * *
# SCHEDULE_NEWS=0 13 * * *
# SCHEDULE_AI_NEWS=0 19 * * *
